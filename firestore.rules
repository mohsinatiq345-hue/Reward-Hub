rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "mohsinatiq345@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Enforcers ---
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 5); // Allow small queries for referral lookups
      
      allow create: if isSignedIn() && isOwner(userId);
      
      allow update: if isSignedIn() && (
        (isOwner(userId) && (
          // Action: Earn points / First task
          (incoming().diff(existing()).affectedKeys().hasOnly(['points', 'hasPerformedFirstTask'])) ||
          // Action: Create withdrawal / Deduct points
          (incoming().diff(existing()).affectedKeys().hasOnly(['points'])) ||
          // Action: Update notification
          (incoming().diff(existing()).affectedKeys().hasOnly(['notification']))
        )) ||
        isAdmin()
      );
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin(); // Admin verifies or rejects
    }
  }
}
