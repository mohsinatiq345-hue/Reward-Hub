{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile with points balance and referral data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "points": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "notification": { 
          "type": "object",
          "properties": {
            "message": { "type": "string" },
            "type": { "type": "string", "enum": ["info", "success", "error"] },
            "timestamp": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "points", "referralCode"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "History of points earned",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["ad", "referral_bonus"] },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "points", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Records of cash-out requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amountPoints": { "type": "number" },
        "amountRs": { "type": "number" },
        "method": { "type": "string", "enum": ["JazzCash", "EasyPaisa"] },
        "accountName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amountPoints", "method", "accountName", "accountNumber", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Point earning history"
    },
    "withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Payment requests"
    }
  }
}
